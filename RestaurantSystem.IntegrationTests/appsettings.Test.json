{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=restaurant_test;Username=test;Password=test"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost" ]
  },
  "JwtSettings": {
    "Secret": "test-secret-key-for-integration-tests-minimum-32-characters",
    "Issuer": "RestaurantSystem.Test",
    "Audience": "RestaurantSystem.Test",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "RateLimiter": {
    "AuthPermitLimit": 3,
    "AuthWindowMinutes": 1,
    "ForgotPasswordPermitLimit": 3,
    "ForgotPasswordWindowHours": 1,
    "RegisterPermitLimit": 3,
    "RegisterWindowHours": 1,
    "ConfirmationEmailPermitLimit": 3,
    "ConfirmationEmailWindowMinutes": 1
  }
}
